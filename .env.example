# Server
PORT=10000
NODE_ENV=production

# Firebase Admin (server-side only — NEVER expose in client)
FIREBASE_PROJECT_ID=projectt3-8c55e
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# MongoDB
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/db
DB_NAME=db

# Redis
REDIS_URL=redis://default:password@host:port

# Cloudflare R2 (server-side only — NEVER expose in client)
CLOUDFLARE_ENDPOINT=
BUCKET_NAME=
ACCESS_KEY=
SECRET_KEY=
R2_PUBLIC_URL=

# Cloudflare TURN (server-side only)
CLOUDFLARE_TURN_TOKEN_ID=
CLOUDFLARE_TURN_API_TOKEN=

# Social Club Admin
SOCIAL_CLUB_ADMIN_TOKEN=
